# Database connection string (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/panini_wishlist"

# Encryption keys (min. 32 characters each)
SECRET_KEY=""           # Used for encrypting Panini passwords
SESSION_SECRET=""       # Used for signing session tokens

# Frontend URL (used by Flask CORS)
FRONTEND_URL="http://localhost:3000"

# Flask backend URL (used by Next.js API routes to reach the Python backend)
BACKEND_URL="http://localhost:8000"

# Flask backend port
BACKEND_PORT=8000

# Flask API key for authenticating requests between Next.js and Flask
FLASK_API_KEY=""

# CSP backend URL (used by middleware for Content-Security-Policy connect-src)
FLASK_BACKEND_URL="http://localhost:5000"

# Application domain (used for QR codes and referer checks)
NEXT_PUBLIC_APP_DOMAIN="panini.entcheneric.com"

# Debug routes (only enable in development)
ENABLE_DEBUG_ROUTES=""